// 1. Configuración del cliente de Prisma
generator client {
  provider = "prisma-client-js"
}

// 2. Configuración de la Base de Datos (PostgreSQL)
datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// MODELOS DE LA BASE DE DATOS (Arquitectura Multi-Sucursal)
// ------------------------------------------------------

// Tabla de Sucursales
model Branch {
  id        Int        @id @default(autoincrement())
  name      String     
  location  String?    
  
  users     User[]     // CAMBIO M:N: Empleados que tienen permiso en esta sucursal
  stocks    Stock[]    
  movements Movement[] 
  sales     Sale[]     
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Tabla de Usuarios
model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String     
  role      String     @default("EMPLOYEE") 
  
  branches  Branch[]   // CAMBIO M:N: Sucursales a las que este usuario tiene acceso
  
  movements Movement[] 
  sales     Sale[]     
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Tabla del Catálogo Central de Productos
model Product {
  id            Int        @id @default(autoincrement())
  sku           String     @unique 
  barcode       String?    @unique 
  
  name          String     
  brand         String     
  category      String     
  description   String?
  
  // ==========================================
  // NUEVO: NÚCLEO FINANCIERO E IMPUESTOS
  // ==========================================
  costPrice      Float?    // Costo de compra al proveedor (Sin IVA)
  retailPrice    Float?    // Precio de venta Minorista (Mostrador)
  wholesalePrice Float?    // Precio de venta Mayorista (Gremio)
  ivaPercentage  Float     @default(21.0) // Porcentaje de IVA aplicable
  // ==========================================

  color         String?  
  finish        String?  
  volume        Float?   
  volumeUnit    String?  
  indoorOutdoor Boolean    @default(true)
  baseType      String?  
  metadata      Json?
  images        String[]   @default([]) 
  
  stocks        Stock[]    
  movements     Movement[] 
  saleItems     SaleItem[] 
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}
// Tabla de Stock (El puente físico)
model Stock {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(0) 
  minStock  Int      @default(5) 
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
}

// MÓDULO DE AUDITORÍA Y TRAZABILIDAD
model Movement {
  id        Int      @id @default(autoincrement())
  type      String   // Ej: "IN", "OUT", "ADJUST"
  quantity  Int      
  reason    String?  
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  
  userId    Int      
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) 
}

// ------------------------------------------------------
// MÓDULO DE VENTAS Y FINANZAS (Caja Registradora)
// ------------------------------------------------------

model Sale {
  id            Int        @id @default(autoincrement())
  totalAmount   Float      
  paymentMethod String     
  
  branchId      Int
  branch        Branch     @relation(fields: [branchId], references: [id])
  
  userId        Int        
  user          User       @relation(fields: [userId], references: [id])
  
  items         SaleItem[] 
  
  createdAt     DateTime   @default(now())
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  quantity    Int      
  unitPrice   Float    
  subtotal    Float    
  
  saleId      Int
  sale        Sale     @relation(fields: [saleId], references: [id])
  
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
}