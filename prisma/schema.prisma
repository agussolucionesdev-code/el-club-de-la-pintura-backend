// 1. Configuración del cliente de Prisma (El conector con Node.js)
generator client {
  provider = "prisma-client-js"
}

// 2. Configuración de la Base de Datos (PostgreSQL)
datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// MODELOS DE LA BASE DE DATOS (Arquitectura Multi-Sucursal)
// ------------------------------------------------------

// Tabla de Sucursales
model Branch {
  id        Int        @id @default(autoincrement())
  name      String     // ej: "Sucursal Temperley"
  location  String?    // Dirección física
  users     User[]     // Empleados que trabajan acá
  stocks    Stock[]    // Inventario específico de esta sucursal
  movements Movement[] // NUEVO: Historial de movimientos de la sucursal
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Tabla de Usuarios (Empleados/Administradores)
model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String     // Contraseña encriptada
  role      String     @default("EMPLOYEE") // Puede ser "ADMIN" o "EMPLOYEE"
  
  // Relación: Un usuario pertenece a una sucursal
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  movements Movement[] // NUEVO: Registro de qué movimientos hizo este usuario
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Tabla del Catálogo Central de Productos
model Product {
  id            Int        @id @default(autoincrement())
  barcode       String     @unique // Código de barras o SKU
  name          String     // ej: "Latex Interior Blanco 20L"
  brand         String     // ej: "Alba", "Colorín"
  category      String     // ej: "Latex", "Sintetico", "Accesorios"
  description   String?
  
  // Atributos específicos de pintura
  color         String?  
  finish        String?  
  volume        Float?   
  volumeUnit    String?  
  indoorOutdoor Boolean    @default(true)
  baseType      String?  
  
  // Atributos dinámicos para escalabilidad
  metadata      Json?
  
  // Alojamiento de URLs de Cloudinary
  images        String[]   @default([]) 
  
  stocks        Stock[]    
  movements     Movement[] // NUEVO: Historial de movimientos de este producto
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// Tabla de Stock (El puente físico)
model Stock {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(0) // Cantidad actual física en el local
  minStock  Int      @default(5) // Umbral crítico para alertas
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
}

// ------------------------------------------------------
// MÓDULO DE AUDITORÍA Y TRAZABILIDAD
// ------------------------------------------------------
model Movement {
  id          Int      @id @default(autoincrement())
  type        String   // Ej: "IN" (Ingreso), "OUT" (Egreso), "ADJUST" (Ajuste/Rotura)
  quantity    Int      // Cantidad de unidades movidas en esta operación
  reason      String?  // Ej: "Venta Ticket #1234", "Ingreso Proveedor", "Mercadería dañada"
  
  // Relaciones obligatorias para trazabilidad total
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id])
  
  userId      Int      // El empleado responsable del movimiento
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now()) // Fecha y hora exacta de la operación
}