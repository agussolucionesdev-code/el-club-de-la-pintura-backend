// 1. Database Client Configuration
generator client {
  provider = "prisma-client-js"
}

// 2. Database Connection (PostgreSQL)
// Connection URL is configured in prisma.config.ts (Prisma v7 requirement)
datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// DATABASE MODELS (Multi-Branch Architecture & ERP)
// ------------------------------------------------------

// Manage physical branches and locations
model Branch {
  id       Int     @id @default(autoincrement())
  name     String
  location String?
  isActive Boolean @default(true)

  users     User[] // M:N: Employees assigned to this branch
  stocks    Stock[]
  movements Movement[]
  sales     Sale[]
  payments  Payment[] // Track physical money entering this branch

  // Track shifts in this branch
  cashRegisters CashRegister[]

  // NEW: Track daily operational expenses for this branch
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Manage system users, credentials and roles
model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("EMPLOYEE")

  branches Branch[] // M:N: Branches this user can operate in

  movements Movement[]
  sales     Sale[]
  payments  Payment[] // Track which employee collected the money

  // Track shifts opened by this user
  cashRegisters CashRegister[]

  // NEW: Track which employee registered an expense
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// CUSTOMER & ACCOUNTS RECEIVABLE MODULE
// ==========================================
// Store client profiles, contractors, and companies
model Customer {
  id       Int     @id @default(autoincrement())
  name     String
  document String? @unique // DNI or CUIT
  type     String  @default("CONSUMER") // e.g., CONSUMER, CONTRACTOR, COMPANY, FAMILY
  phone    String?
  email    String?
  address  String?

  // Credit control fields
  creditLimit     Int @default(0) // Maximum allowed outstanding balance (0 = unlimited)
  defaultDiscount Int @default(0) // Automatic discount percentage applied in POS (0–100)

  // ==========================================
  // INYECCIÓN DE SEGURIDAD FISCAL (Soft Delete)
  // ==========================================
  isActive Boolean @default(true)

  sales Sale[] // Relate billing and debts to this specific customer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// SUPPLIER MODULE (Proveedores)
// ==========================================
// Store supplier companies and contact representatives for WhatsApp orders
model Supplier {
  id          Int     @id @default(autoincrement())
  companyName String // Name of the company (e.g., Alba, Sherwin Williams)
  cuit        String? @unique
  contactName String? // Representative (e.g., "Juan Perez - Corredor")
  phone       String // CRITICAL: Used for WhatsApp integration
  email       String?
  address     String?
  isActive    Boolean @default(true) // Soft delete

  products Product[] // M:1: Products supplied by this company
  expenses Expense[] // Expenses paid to this supplier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Manage central product catalog and financial pricing
model Product {
  id      Int     @id @default(autoincrement())
  sku     String  @unique
  barcode String? @unique

  name        String
  brand       String
  category    String
  description String?

  // 🛡️ MOTOR FINANCIERO ERP
  costPrice      Decimal? @db.Decimal(14, 4) // Costo del Proveedor (Sin IVA)
  profitMargin   Decimal  @default(30.0) @db.Decimal(7, 4) // Margen de Ganancia (%)
  ivaPercentage  Decimal  @default(21.0) @db.Decimal(7, 4) // Impuesto (%)
  retailPrice    Decimal? @db.Decimal(14, 4) // Precio Final al Público
  wholesalePrice Decimal? @db.Decimal(14, 4) // Precio Mayorista (Opcional)

  color         String?
  finish        String?
  volume        Float?
  volumeUnit    String?
  indoorOutdoor Boolean  @default(true)
  baseType      String?
  metadata      Json?
  images        String[] @default([])

  isActive Boolean @default(true)

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  stocks    Stock[]
  movements Movement[]
  saleItems SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Manage physical inventory levels per branch
model Stock {
  id       Int @id @default(autoincrement())
  quantity Int @default(0)
  minStock Int @default(5)

  // INYECCIÓN RECUPERADA: Semáforo Dinámico
  criticalStock Int @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([branchId])
}

// Track every physical movement of goods (Audit Trail)
model Movement {
  id       Int     @id @default(autoincrement())
  type     String // IN, OUT, ADJUST
  quantity Int
  reason   String?

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([productId, branchId])
}

// ==========================================
// SHIFT & CASH REGISTER MODULE
// ==========================================
model CashRegister {
  id          Int       @id @default(autoincrement())
  openingTime DateTime  @default(now())
  closingTime DateTime? // Null means the shift is currently OPEN

  initialBalance  Decimal  @db.Decimal(14, 2) // Fondo de caja (Sencillo para dar vuelto)
  expectedBalance Decimal? @db.Decimal(14, 2) // Calculado por el sistema al cerrar
  actualBalance   Decimal? @db.Decimal(14, 2) // Contado por el empleado al cerrar
  discrepancy     Decimal? @db.Decimal(14, 2) // Diferencia (Sobrante o Faltante)

  status       String  @default("OPEN") // OPEN, CLOSED
  observations String? // Notas sobre faltantes o retiros

  userId Int // Empleado que abrió la caja
  user   User @relation(fields: [userId], references: [id])

  branchId Int // Sucursal donde se operó
  branch   Branch @relation(fields: [branchId], references: [id])

  sales    Sale[] // Ventas vinculadas a este turno
  payments Payment[] // Cobranzas vinculadas a este turno

  // NEW: Gastos operativos que salieron del cajón durante este turno
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([userId])
}

// ==========================================
// NEW: EXPENSE MODULE (Gastos Operativos diarios)
// ==========================================
model Expense {
  id       Int     @id @default(autoincrement())
  amount   Decimal @db.Decimal(14, 2) // Dinero físico retirado de la caja
  reason   String // Ej: "Compra lavandina", "Pago a fletero"
  category String // Ej: "LIMPIEZA", "LOGISTICA", "OTROS"

  // INYECCIÓN RECUPERADA: Clasificación Financiera Estructural (Fijo vs Variable)
  type String @default("VARIABLE") // "FIXED" or "VARIABLE"

  // Link to the exact shift from which the money was taken
  cashRegisterId Int
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  userId Int // Employee who registered the expense
  user   User @relation(fields: [userId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  // ── Soft-void (anulación con motivo) — preserves the audit trail ──
  voidedAt   DateTime? // When the expense was annulled (null = active)
  voidReason String? // Why it was annulled
  voidedById Int? // User id who annulled it (plain ref, no relation)

  // ── Receipt image (factura/ticket) — Cloudinary URL ──
  receiptImageUrl String?

  // ── Optional link to the supplier paid ──
  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  // ── If generated from a recurring template (plain ref) ──
  recurringExpenseId Int?

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([cashRegisterId])
  @@index([voidedAt])
  @@index([supplierId])
}

// ==========================================
// EXPENSE BUDGETS (Presupuestos de gastos)
// ==========================================
// Monthly spending ceiling, global (branchId/category = null) or scoped.
model ExpenseBudget {
  id        Int      @id @default(autoincrement())
  branchId  Int? // null = applies to all branches
  category  String? // null = applies to all categories (global budget)
  amount    Decimal  @db.Decimal(14, 2)
  period    String   @default("MONTHLY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, category])
}

// ==========================================
// RECURRING EXPENSES (Gastos recurrentes/programados)
// ==========================================
// Template that the operator can instantiate into a real expense in one click.
model RecurringExpense {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(14, 2)
  reason      String
  category    String
  type        String   @default("VARIABLE")
  frequency   String   @default("MONTHLY") // MONTHLY | WEEKLY
  branchId    Int
  supplierId  Int? // plain ref
  active      Boolean  @default(true)
  createdById Int // plain ref
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId, active])
}

// ------------------------------------------------------
// SALES, DEBT & CASH FLOW MODULE
// ------------------------------------------------------

// Generate billing tickets and track pending balances (Fiados)
model Sale {
  id            Int     @id @default(autoincrement())
  totalAmount   Decimal @db.Decimal(14, 2)
  paymentMethod String // CASH, CARD, CREDIT_ACCOUNT

  status     String  @default("PAID") // PAID, PENDING, PARTIAL
  balance    Decimal @default(0) @db.Decimal(14, 2) // Pending amount to be paid
  pickedUpBy String? // Name/ID of the person who physically took the items

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  // Link to the active shift
  cashRegisterId Int?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  items    SaleItem[]
  payments Payment[] // Link partial or full payments to this ticket
  returns  Return[] // Partial or full returns against this sale

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([cashRegisterId])
  @@index([userId])
  @@index([customerId])
  @@index([status])
}

// Record individual billing rows with frozen historical costs
model SaleItem {
  id        Int      @id @default(autoincrement())
  quantity  Int
  unitPrice Decimal  @db.Decimal(14, 4) // Final price actually charged (post-discount)
  subtotal  Decimal  @db.Decimal(14, 2)
  unitCost  Decimal? @db.Decimal(14, 4) // Frozen cost snapshot
  listPrice   Decimal? @db.Decimal(14, 4) // Original list price before any discount
  discountPct Decimal? @db.Decimal(7, 4)  // Discount % applied to this line (0-100)

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// Register physical money entering the drawer (Cash Flow)
model Payment {
  id            Int     @id @default(autoincrement())
  amount        Decimal @db.Decimal(14, 2) // Physical money collected
  paymentMethod String // CASH, TRANSFER, etc.

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id])

  userId Int // Cashier who collected the money
  user   User @relation(fields: [userId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  // Link to the active shift
  cashRegisterId Int?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([cashRegisterId])
  @@index([branchId, createdAt])
}

// ==========================================
// RMA & RETURNS MODULE
// ==========================================
model Return {
  id             Int      @id @default(autoincrement())
  saleId         Int
  sale           Sale     @relation(fields: [saleId], references: [id])
  reason         String
  branchId       Int
  createdById    Int
  totalRefund    Decimal  @db.Decimal(14, 2)
  // JSON snapshot: [{saleItemId, productId, quantity, refundedUnitPrice}]
  items          Json
  cashRegisterId Int?
  createdAt      DateTime @default(now())

  @@index([saleId])
  @@index([branchId])
}

// ------------------------------------------------------
// ERP OFFLINE / AUDIT / INTERNAL OPERATIONS SCAFFOLDING
// ------------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId Int?
  branchId    Int?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([branchId])
  @@index([entityType, entityId])
}

model SyncOperation {
  id             String    @id @default(uuid())
  idempotencyKey String    @unique
  branchId       Int?
  userId         Int?
  type           String
  status         String    @default("PENDING")
  payload        Json
  error          String?
  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  @@index([branchId])
  @@index([userId])
  @@index([status])
}

model SyncCheckpoint {
  id           Int       @id @default(autoincrement())
  deviceId     String
  userId       Int
  branchId     Int?
  lastPulledAt DateTime?
  lastPushedAt DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([deviceId, userId, branchId])
}

model StockTransfer {
  id           String   @id @default(uuid())
  productId    Int
  fromBranchId Int
  toBranchId   Int
  quantity     Int
  reason       String?
  userId       Int
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  supplierId Int?
  branchId   Int
  status     String   @default("DRAFT")
  items      Json
  createdBy  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([supplierId])
  @@index([branchId])
}

model PurchaseReceipt {
  id              String   @id @default(uuid())
  purchaseOrderId String?
  supplierId      Int?
  branchId        Int
  items           Json
  receivedBy      Int
  receivedAt      DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([branchId])
}

model InternalReceipt {
  id             String   @id @default(uuid())
  receiptNumber  String   @unique
  receiptType    String
  branchId       Int
  cashRegisterId Int?
  saleId         Int?
  paymentId      Int?
  payload        Json
  createdBy      Int
  createdAt      DateTime @default(now())

  @@index([branchId])
  @@index([saleId])
  @@index([paymentId])
}

// ==========================================
// PAYROLL MODULE — Employee salary management
// ==========================================

model Employee {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  position   String // e.g. "Vendedor", "Encargado"
  salaryType String   @default("FIXED") // FIXED | HOURLY | COMMISSION
  baseSalary Decimal  @db.Decimal(12, 2)
  branchId   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payrollRecords PayrollRecord[]

  @@index([branchId])
  @@index([userId])
}

model PayrollRecord {
  id           Int       @id @default(autoincrement())
  employeeId   Int
  employee     Employee  @relation(fields: [employeeId], references: [id])
  period       String // "YYYY-MM"
  baseSalary   Decimal   @db.Decimal(12, 2)
  advances     Decimal   @default(0) @db.Decimal(12, 2)
  bonuses      Decimal   @default(0) @db.Decimal(12, 2)
  deductions   Decimal   @default(0) @db.Decimal(12, 2)
  netPay       Decimal   @db.Decimal(12, 2)
  status       String    @default("PENDING") // PENDING | PAID
  paidAt       DateTime?
  observations String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, period])
  @@index([period])
  @@index([status])
}

// Tracks bulk price-update jobs so job status survives server restarts.
// Previously stored in-memory only (Map<string, JobState>) which lost state
// on any restart or crash.
model BulkPriceJob {
  id           String   @id @default(uuid())
  userId       Int
  filename     String
  status       String   @default("PENDING") // PENDING | PROCESSING | DONE | ERROR
  processed    Int      @default(0)
  total        Int      @default(0)
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  errors       Json?    // Array of { row, sku, message } for failed rows (capped at 200)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  finishedAt   DateTime?

  @@index([userId])
  @@index([status])
}
