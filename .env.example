# --- Server --------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# --- Database ------------------------------------------------------------------
# PostgreSQL connection string (Prisma format)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/el_club_pintura?schema=public

# --- Auth ----------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# --- CORS ----------------------------------------------------------------------
# URL of the frontend — only this origin is allowed to call the API
FRONTEND_URL=http://localhost:5174

# --- Cloudinary (product image uploads) ----------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Admin onboarding ----------------------------------------------------------
# Secret required to create the first ADMIN user via POST /api/users/onboard
ADMIN_ONBOARD_SECRET=change_this_to_a_random_secret
