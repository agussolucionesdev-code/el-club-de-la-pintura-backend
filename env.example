# Rename this file to .env before running the server locally.
# On Render: add these under Environment > Environment Variables.

NODE_ENV=development
PORT=4000

# PostgreSQL — Supabase / Render Postgres / Neon connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=24h

# First ADMIN user creation
ADMIN_ONBOARD_SECRET=replace_with_random_secret

# Allowed frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5174

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
